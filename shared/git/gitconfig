[alias]
    s = status
    d = diff
    ds = diff --staged
    co = checkout
    br = branch
    ci = commit
    lg = log --oneline --graph --decorate -20
    last = log -1 HEAD
    unstage = reset HEAD --
    amend = commit --amend --no-edit

[core]
    editor = nano
    autocrlf = input

[pull]
    rebase = true

[push]
    default = current

[init]
    defaultBranch = main
